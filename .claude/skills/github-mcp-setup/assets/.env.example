# GitHub App Configuration for Claude Code MCP

# Numeric ID of your GitHub App
# Find this in: GitHub Settings → Developer settings → GitHub Apps → Your App → About
GITHUB_APP_ID=

# Path to the GitHub App's private key file (PEM format)
# Store the key file in .github/app-private-key.pem and add to .gitignore
# Download from: GitHub Settings → Developer settings → GitHub Apps → Your App → Private keys
GITHUB_APP_PRIVATE_KEY_PATH=.github/app-private-key.pem

# Numeric ID of the installation of your GitHub App
# Find this in the URL after installing the app:
# https://github.com/settings/installations/{INSTALLATION_ID}
# Or navigate to: GitHub Settings → Installed GitHub Apps → Configure
GITHUB_INSTALLATION_ID=
